    },
    "euroArabDialogue": {
      "title": "Euro-Arab Cities Dialogue",
      "intro": "An expanded dialogue platform bringing together decision-makers and city leaders from Arab and European cities to exchange expertise and practices in urban development, and discuss shared challenges and cooperation opportunities in urban planning, sustainability, and innovation.",
      "image": "/partnerships/euro-arab-dialogue.png"
    },
    "secretarySpeaks": {
      "title": "The Secretary-General Speaks",
      "intro": "A series of meetings and dialogues with the Secretary-General of the Organization of Arab Cities and municipal leaders, highlighting the visions and experiences of Arab cities in addressing urban challenges and strengthening partnerships for sustainable development.",
      "image": "/partnerships/secretary-speaks.png"
    },
    "urbanAwards": {
      "title": "Arab Cities Urban Development Awards",
      "intro": "A recognition initiative encouraging Arab cities to adopt best practices in urban development, and highlighting outstanding initiatives in planning, municipal management, and environmental sustainability.",
      "image": "/partnerships/urban-awards.png"
    },
    "partnersGuide": {
      "title": "Urban Development Partners Guide",
      "intro": "A comprehensive reference featuring the Institute's partner network of government institutions, universities, and international and regional organizations, providing information on cooperation areas and partnership mechanisms to support urban development in Arab cities.",
      "image": "/partnerships/partners-guide.png"
    }
