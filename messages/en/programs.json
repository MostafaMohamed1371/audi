  "partnerships": {
    "back": "Back",
    "heroIntro": "Amid the development shifts facing Arab cities, the Arab Urban Development Institute seeks to strengthen its role as a leading think tank supporting cities through sharing advanced ideas and practices, building institutional capacities in municipalities, and serving as a platform for effective communication and knowledge exchange among cities, universities, and regional and international organizations.",
    "sectionsLabel": "Program Sections",
