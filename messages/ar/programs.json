    "euroArabDialogue": {
      "title": "حوار المدن العربية الأوروبية",
      "intro": "منصة حوار موسعة تجمع صناع القرار وقادة المدن العربية والأوروبية لتبادل الخبرات والممارسات في التنمية الحضرية، ومناقشة التحديات المشتركة وفرص التعاون في مجالات التخطيط الحضري والاستدامة والابتكار.",
      "image": "/partnerships/euro-arab-dialogue.png"
    },
    "secretarySpeaks": {
      "title": "الأمين يتحدث",
      "intro": "سلسلة من اللقاءات والحوارات مع الأمين العام لمنظمة المدن العربية والقيادات البلدية، تسلّط الضوء على رؤى وتجارب المدن العربية في مواجهة التحديات الحضرية وتعزيز الشراكات من أجل تنمية مستدامة.",
      "image": "/partnerships/secretary-speaks.png"
    },
    "urbanAwards": {
      "title": "جوائز التنمية الحضرية للمدن العربية",
